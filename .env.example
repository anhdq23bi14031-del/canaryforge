# CanaryForge environment configuration
# Copy this to .env and fill in your values

# ── Core ────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
BASE_URL=http://localhost:8000
DEBUG=false

# ── Database ─────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./canaryforge.db

# PostgreSQL (for Railway/production)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/canaryforge

# ── LLM (for decoy doc generation) ──────────────────
ANTHROPIC_API_KEY=

# ── Slack alerts ─────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Email alerts ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=canaryforge@yourdomain.com
ALERT_TO_EMAIL=security@yourdomain.com

# ── Scoring thresholds ───────────────────────────────
ALERT_SCORE_THRESHOLD=40
FALSE_POSITIVE_SCORE=10

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:3000"]
